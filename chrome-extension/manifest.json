{
  "manifest_version": 3,
  "name": "ProspectOS",
  "version": "1.0.0",
  "description": "Crea listas de cuentas en Sales Navigator desde ProspectOS",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://localhost:3000/*",
    "https://*.vercel.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/sales/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
